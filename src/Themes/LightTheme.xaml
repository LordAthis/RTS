<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="BgColor">#F5F5F5</Color>
    <Color x:Key="AccentNeon">#008F24</Color> <Color x:Key="SecondaryNeon">#0097A7</Color> 
    <SolidColorBrush x:Key="WindowBorderBrush" Color="{StaticResource AccentNeon}"/>
    <SolidColorBrush x:Key="MainBgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="#212121"/>
</ResourceDictionary>
