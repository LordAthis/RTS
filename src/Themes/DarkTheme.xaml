<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Nyers színek (Color) -->
    <Color x:Key="BgColor">#0A0A0A</Color>
    <Color x:Key="AccentColor">#00FF41</Color> 
    <Color x:Key="SecondaryColor">#00E5FF</Color>

    <!-- Ecsetek (Brush) - Ezeket használja a Foreground/Background -->
    <SolidColorBrush x:Key="AccentNeon" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="SecondaryNeon" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="WindowBorderBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="MainBgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="White"/>

</ResourceDictionary>
