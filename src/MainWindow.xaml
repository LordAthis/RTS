<Window x:Class="RTS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexus RTS" Height="650" Width="1100"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Border CornerRadius="20" Background="{DynamicResource MainBgBrush}" 
                BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2">
            <Grid>
                <Border Height="50" VerticalAlignment="Top" Background="#000" CornerRadius="18,18,0,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0">
                            <TextBlock Text="NEXUS" Foreground="{DynamicResource AccentNeon}" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="Bit&amp;Chip s.r.o." Foreground="Gray" FontSize="14" Margin="15,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0">
                             </StackPanel>
                    </Grid>
                </Border>

                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="15" Orientation="Horizontal">
                    <Button x:Name="BtnThemeToggle" Content="🌓" Width="40" Height="40" Click="BtnThemeToggle_Click" 
                            Style="{StaticResource FloatingButtonStyle}"/>
                    <Button x:Name="BtnExit" Content="✕" Width="40" Height="40" Margin="10,0" Click="BtnExit_Click" 
                            Style="{StaticResource ExitButtonStyle}"/>
                </StackPanel>
                
                <Grid Margin="10,60,10,70">
                    </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
