<Window x:Class="RTS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexus RTS" Height="700" Width="1200"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <Storyboard x:Key="WorkingAnimation">
            <ColorAnimation Storyboard.TargetName="MainBorder" 
                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="{StaticResource SecondaryNeon}" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Border x:Name="MainBorder" CornerRadius="20" Background="{DynamicResource MainBgBrush}" 
                BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/> <ColumnDefinition Width="1*"/> </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/> <RowDefinition Height="*"/>  </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                    <Button Content="🏠" Style="{StaticResource NeonButtonStyle}" Width="40" Margin="0,0,10,0"/>
                    <StackPanel Orientation="Horizontal" Background="#222" CornerRadius="10" Padding="5">
                        <Button Content="XP" Style="{StaticResource NeonButtonStyle}" Margin="2"/>
                        <Button Content="7" Style="{StaticResource NeonButtonStyle}" Margin="2"/>
                        <Button Content="8" Style="{StaticResource NeonButtonStyle}" Margin="2"/>
                        <Button Content="10" Style="{StaticResource NeonButtonStyle}" Margin="2"/>
                        <Button Content="11" Style="{StaticResource NeonButtonStyle}" Margin="2"/>
                    </StackPanel>
                    
                    <Border Background="Black" CornerRadius="10" Margin="20,0" Padding="20,0">
                        <TextBlock Text="NEXUS Bit&amp;Chip" Foreground="{DynamicResource AccentNeon}" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="🛠️ RTS" Style="{StaticResource NeonButtonStyle}" Margin="5,0"/>
                        <Button Content="📦 IWS" Style="{StaticResource NeonButtonStyle}" Margin="5,0"/>
                        <Button Content="🌐" Style="{StaticResource NeonButtonStyle}" Margin="5,0"/>
                        <Button Content="⚙️ ATI" Style="{StaticResource NeonButtonStyle}" Margin="5,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,10,0">
                    <Border Height="60" Background="#1A1A1A" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
                        <TextBlock x:Name="TxtInfo" Text="Válassz egy modult a kezdéshez..." Foreground="Gray" Margin="10" VerticalAlignment="Center"/>
                    </Border>
                    <Border Height="450" Margin="0,10,0,0" Background="#0F0F0F" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
                        <ContentControl x:Name="MainContentArea"/>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/> <RowDefinition Height="1*"/> <RowDefinition Height="1*"/> <RowDefinition Height="50"/> </Grid.RowDefinitions>

                    <Border Grid.Row="0" Margin="0,0,0,5" Background="#1A1A1A" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
                        <TextBlock Text="B1: Gyorselérés" Foreground="DimGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Row="1" Margin="0,5" Background="#1A1A1A" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
                        <TextBlock Text="B2: Eszközök" Foreground="DimGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <Border Grid.Row="2" Margin="0,5" Background="Black" CornerRadius="10" BorderBrush="{DynamicResource AccentNeon}" BorderThickness="1">
                        <ScrollViewer>
                            <TextBlock x:Name="TxtLog" Text="[RTS Log indítása...]" Foreground="{DynamicResource AccentNeon}" FontFamily="Consolas" FontSize="10" Margin="5"/>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Content="GH" Style="{StaticResource NeonButtonStyle}" Width="35" Margin="2"/>
                        <Button Content="W" Style="{StaticResource NeonButtonStyle}" Width="35" Margin="2"/>
                        <Button Content="L" Style="{StaticResource NeonButtonStyle}" Width="35" Margin="2"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
