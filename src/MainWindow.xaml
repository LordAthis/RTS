<Window x:Class="RTS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexus RTS" Height="700" Width="1200"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Storyboard x:Key="WorkingAnimation">
            <ColorAnimation Storyboard.TargetName="MainBorder" 
                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="{DynamicResource SecondaryNeon}" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Border x:Name="MainBorder" CornerRadius="20" Background="{DynamicResource MainBgBrush}" 
                BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2">
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button x:Name="BtnHome" Content="🏠" Style="{StaticResource NeonButtonStyle}" Width="45" Height="40" Margin="0,0,10,0" Click="Module_Click"/>
                    
                    <Border Background="#1A1A1A" CornerRadius="10" Padding="5">
    <StackPanel Orientation="Horizontal">
        <!-- Itt maradnak a gombok (BtnXP, BtnWin7, stb.) -->
    </StackPanel>
</Border>

                        <Button x:Name="BtnXP" Content="XP" Style="{StaticResource NeonButtonStyle}" Width="40" Margin="2" Click="Module_Click"/>
                        <Button x:Name="BtnWin7" Content="7" Style="{StaticResource NeonButtonStyle}" Width="40" Margin="2" Click="Module_Click"/>
                        <Button x:Name="BtnWin8" Content="8" Style="{StaticResource NeonButtonStyle}" Width="40" Margin="2" Click="Module_Click"/>
                        <Button x:Name="BtnWin10" Content="10" Style="{StaticResource NeonButtonStyle}" Width="40" Margin="2" Click="Module_Click"/>
                        <Button x:Name="BtnWin11" Content="11" Style="{StaticResource NeonButtonStyle}" Width="40" Margin="2" Click="Module_Click"/>
                    </StackPanel>
                    
                    <Border Background="Black" CornerRadius="12" Margin="20,0" Padding="25,5" BorderBrush="#333" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="NEXUS" Foreground="{DynamicResource AccentNeon}" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Text="Bit&amp;Chip s.r.o." Foreground="Gray" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnRTS" Content="🛠️ RTS" Style="{StaticResource NeonButtonStyle}" Width="80" Margin="5,0" Click="Module_Click"/>
                        <Button x:Name="BtnIWS" Content="📦 IWS" Style="{StaticResource NeonButtonStyle}" Width="80" Margin="5,0" Click="Module_Click"/>
                        <Button x:Name="BtnNet" Content="🌐 NET" Style="{StaticResource NeonButtonStyle}" Width="80" Margin="5,0" Click="Module_Click"/>
                        <Button x:Name="BtnATI" Content="⚙️ ATI" Style="{StaticResource NeonButtonStyle}" Width="80" Margin="5,0" Click="Module_Click"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,15,15,0">
                    <Border Height="70" Background="#111" CornerRadius="12" BorderBrush="#222" BorderThickness="1">
                        <TextBlock x:Name="TxtInfo" Text="Rendszer készenlétben..." Foreground="Gray" Margin="15" VerticalAlignment="Center" FontSize="14" FontStyle="Italic"/>
                    </Border>
                    <Border x:Name="A2_Area" Height="480" Margin="0,15,0,0" Background="#0A0A0A" CornerRadius="12" BorderBrush="#222" BorderThickness="1">
                        <ContentControl x:Name="MainContentArea"/>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="1" Grid.Column="1" Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/> <RowDefinition Height="1*"/> <RowDefinition Height="1.5*"/> <RowDefinition Height="50"/> </Grid.RowDefinitions>

                    <Border Grid.Row="0" x:Name="B1_Area" Margin="0,0,0,8" Background="#111" CornerRadius="12" BorderBrush="#222" BorderThickness="1">
                        <TextBlock Text="B1: GYORSELÉRÉS" Foreground="#333" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                    </Border>
                    <Border Grid.Row="1" x:Name="B2_Area" Margin="0,8" Background="#111" CornerRadius="12" BorderBrush="#222" BorderThickness="1">
                        <TextBlock Text="B2: ESZKÖZÖK" Foreground="#333" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                    </Border>
                    
                    <Border Grid.Row="2" Margin="0,8" Background="Black" CornerRadius="12" BorderBrush="{DynamicResource AccentNeon}" BorderThickness="1">
                        <ScrollViewer x:Name="LogScroller">
                            <TextBlock x:Name="TxtLog" Text="[RTS Core Initialized...]" Foreground="{DynamicResource AccentNeon}" FontFamily="Consolas" FontSize="11" Margin="10" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="3" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button x:Name="BtnThemeToggle" Content="🌓" Style="{StaticResource NeonButtonStyle}" Width="35" Height="35" Click="BtnThemeToggle_Click"/>
                            <Button x:Name="BtnExit" Content="✕" Style="{StaticResource ExitButtonStyle}" Width="35" Height="35" Margin="8,0" Click="BtnExit_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnGH" Content="GH" Style="{StaticResource NeonButtonStyle}" Width="35" Height="35" Margin="2"/>
                            <Button x:Name="BtnWeb" Content="W" Style="{StaticResource NeonButtonStyle}" Width="35" Height="35" Margin="2"/>
                            <Button x:Name="BtnLn" Content="L" Style="{StaticResource NeonButtonStyle}" Width="35" Height="35" Margin="2"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
