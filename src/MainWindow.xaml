<Window x:Class="RTS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RTS" Height="650" Width="1100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- NEON GOMB STÍLUS – háttér + hover + click villanás -->
        <Style x:Key="NeonButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#00FF41"/>
            <Setter Property="BorderBrush" Value="#00FF41"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F1F1F"/>
                                <Setter Property="BorderBrush" Value="#00FF9F"/>
                                <Setter Property="Foreground" Value="#00FF9F"/>
                            </Trigger>
                            <!-- Pressed (villanás) -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#00BFFF"/>
                                <Setter Property="BorderBrush" Value="#00FFFF"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- FŐ KERET -->
        <Border x:Name="MainBorder" CornerRadius="20"
                Background="{DynamicResource MainBgBrush}" 
                BorderBrush="#222" BorderThickness="2" 
                Panel.ZIndex="0"
                Margin="20,45,20,20">

            <Grid Margin="15,40,15,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- BAL OLDAL (fő tartalom) -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,0">
                    <Border x:Name="A1_LoadingBorder" Height="70" Background="#111" CornerRadius="12" BorderBrush="#222" BorderThickness="2">
                        <TextBlock x:Name="TxtInfo" Text="Rendszer készenlétben..." Foreground="Gray" Margin="15" VerticalAlignment="Center" FontSize="14" FontStyle="Italic"/>
                    </Border>
                    <Border x:Name="A2_Area" Height="460" Margin="0,15,0,0" Background="#0A0A0A" CornerRadius="12" BorderBrush="#222" BorderThickness="1">
                        <ContentControl x:Name="MainContentArea"/>
                    </Border>
                </StackPanel>

                <!-- JOBB OLDAL (panelek + log) -->
                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" x:Name="B1_Area" Margin="0,0,0,8" Background="#111" CornerRadius="12" BorderBrush="#222" BorderThickness="1">
                        <TextBlock Text="B1: GYORSELÉRÉS" Foreground="#333" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                    </Border>
                    <Border Grid.Row="1" x:Name="B2_Area" Margin="0,8" Background="#111" CornerRadius="12" BorderBrush="#222" BorderThickness="1">
                        <TextBlock Text="B2: ESZKÖZÖK" Foreground="#333" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                    </Border>
                    <Border Grid.Row="2" Margin="0,8" Background="Black" CornerRadius="12" BorderBrush="{DynamicResource AccentNeon}" BorderThickness="1">
                        <ScrollViewer x:Name="LogScroller">
                            <TextBlock x:Name="TxtLog" Text="[RTS Core Initialized...]" Foreground="{DynamicResource AccentNeon}" FontFamily="Consolas" FontSize="11" Margin="10" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>

                    <!-- jobb alsó kis gombok (GH W L) -->
                    <Grid Grid.Row="3" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnGH" Content="GH" Style="{StaticResource NeonButtonStyle}" Width="35" Height="35" Margin="2" Click="BtnGH_Click"/>
                            <Button x:Name="BtnWeb" Content="W" Style="{StaticResource NeonButtonStyle}" Width="35" Height="35" Margin="2"/>
                            <Button x:Name="BtnLn" Content="L" Style="{StaticResource NeonButtonStyle}" Width="35" Height="35" Margin="2"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- FEJLÉC (kilóg felül) – most már XP, 7, 10, 11 gombokkal -->
        <Canvas VerticalAlignment="Top" HorizontalAlignment="Stretch" Height="68" 
                Margin="30,-12,30,0" Panel.ZIndex="2" IsHitTestVisible="True">
            <StackPanel Orientation="Horizontal" Canvas.Left="10" Margin="0,40,0,0">
                <Button x:Name="BtnHome" Content="🏠" Style="{StaticResource NeonButtonStyle}" Width="45" Height="45" Click="Module_Click"/>

                <!-- OS választó gombok -->
                <Border Background="#1A1A1A" CornerRadius="12" Padding="5" Margin="10,0" BorderBrush="#333" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,37,0">
                        <Button x:Name="BtnXP"   Content="XP"  Style="{StaticResource NeonButtonStyle}" Width="35" Margin="2" Click="Module_Click"/>
                        <Button x:Name="BtnWin7" Content="7"   Style="{StaticResource NeonButtonStyle}" Width="35" Margin="2" Click="Module_Click"/>
                        <Button x:Name="BtnWin10" Content="10" Style="{StaticResource NeonButtonStyle}" Width="35" Margin="2" Click="Module_Click"/>
                        <Button x:Name="BtnWin11" Content="11" Style="{StaticResource NeonButtonStyle}" Width="35" Margin="2" Click="Module_Click"/>
                    </StackPanel>
                </Border>

                <Border Background="Black" CornerRadius="15" Padding="20,5" BorderBrush="#444" BorderThickness="1" Margin="20,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="NEXUS" Foreground="{DynamicResource AccentNeon}" VerticalAlignment="Center" FontWeight="Bold" FontSize="35"/>
                        <TextBlock Text="Bit&amp;Chip s.r.o.    " Foreground="{DynamicResource AccentNeon}" VerticalAlignment="Center" FontWeight="Bold" FontSize="20"/>
                    </StackPanel>
                </Border>

                <!-- Modul gombok jobbra -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,37,0">
                    <Button x:Name="BtnRTS" Content="F1" Style="{StaticResource NeonButtonStyle}" Width="85" Margin="3,0" Click="Module_Click"/>
                    <Button x:Name="BtnIWS" Content="📦 IWS" Style="{StaticResource NeonButtonStyle}" Width="85" Margin="3,0" Click="Module_Click"/>
                    <Button x:Name="BtnNet" Content="🌐 NET" Style="{StaticResource NeonButtonStyle}" Width="85" Margin="3,0" Click="Module_Click"/>
                </StackPanel>
            </StackPanel>
        </Canvas>

        <!-- BAL ALSÓ SAROK – lebegő gombok (theme + exit) -->
        <Canvas VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="45,0,0,35" Panel.ZIndex="3" IsHitTestVisible="True">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnThemeToggle" Content="🌓" Style="{StaticResource NeonButtonStyle}" Width="42" Height="42" Margin="12,0,0,250" Click="BtnThemeToggle_Click"/>
                <Button x:Name="BtnExit" Content="✕" Style="{StaticResource NeonButtonStyle}" Width="42" Height="42" Margin="12,0,0,250" Click="BtnExit_Click"/>
            </StackPanel>
        </Canvas>
    </Grid>
</Window>