<Window x:Class="RTS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexus RTS" Height="600" Width="1000"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    
    <Grid>
        <Border CornerRadius="15" Background="#121212" BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Border Height="40" VerticalAlignment="Top" Background="Black" CornerRadius="15,15,0,0" Margin="-1,-1,-1,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="NEXUS" Foreground="#00FF41" FontWeight="Bold" VerticalAlignment="Center" FontSize="18"/>
                        <TextBlock Text="Bit&amp;Chip s.r.o." Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"/>
                    </StackPanel>
                </Border>
                
                </Grid>
        </Border>
    </Grid>
</Window>
